<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:MainViewModel"
             x:Class="Sample.MainPage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit" />

            <Label
                Text="Welcome to Shiny MAUI Shell"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Label Text="Navigation Argument" />
            <Entry Text="{Binding NavArg}" 
                   HorizontalOptions="Fill" />
            
            <Button Text="Navigate By Route"
                    Command="{Binding NavByUriCommand}"
                    HorizontalOptions="Fill" />
            
            <Button Text="Navigate To Modal" 
                    Command="{Binding NavToModalCommand}"
                    HorizontalOptions="Fill" />
            
            <Button Text="Navigate By ViewModel" 
                    Command="{Binding NavByViewModelCommand}"
                    HorizontalOptions="Fill" />

            <Label Text="{Binding BackArg, StringFormat='Back Arg: {0}'}" 
                   IsVisible="{Binding ShowBackArg}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>