<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:AnotherViewModel"
             x:Class="Sample.AnotherPage"
             Title="Another Page">
    <VerticalStackLayout
        Padding="30,0"
        Spacing="25">
        <Label Text="Welcome To Another Page" />

        <Label Text="{Binding Arg, StringFormat='Received Arg: {0}'}" />
        <Label Text="You navigated here by viewmodel" 
               IsVisible="{Binding IsNavFromViewModel}" />
        
        <Button Text="Reset Root"
                Command="{Binding ResetToRootCommand}" />
        
        <Button Text="Push On Another"
                Command="{Binding PushAnotherCommand}" />
        
        <Button Text="Pop to Root" 
                Command="{Binding PopToRootCommand}"/>

        <Button Text="GO BACK" 
                Command="{Binding GoBackCommand}"
                HorizontalOptions="Fill" />
        
        <Entry Text="{Binding BackArg}" 
               Placeholder="Back Argument"
               HorizontalOptions="Fill" />
    </VerticalStackLayout>
</ContentPage>