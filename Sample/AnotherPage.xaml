<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             x:DataType="sample:AnotherViewModel"
             x:Class="Sample.AnotherPage"
             Title="Another Page">
    <ContentPage.Content>
        <VerticalStackLayout>
            <Label Text="Welcome To Another Page" />

            <Label Text="{Binding Arg, StringFormat='Received Arg: {0}'}" />
            <Label Text="You navigated here by viewmodel" 
                   IsVisible="{Binding IsNavFromViewModel}" />
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>